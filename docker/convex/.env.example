# Docker port mapping
CONVEX_VERSION=latest

# Docker port mapping
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791
WEB_PORT=3000
WORKER_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional backend identity label
INSTANCE_NAME=f1-pace-lab-local

# Optional logging level: error,warn,info,debug,trace
RUST_LOG=info

# Dashboard -> backend URL (keep aligned with PORT unless you have a reverse proxy)
NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210

# Keep metrics off by default for local setup
DISABLE_METRICS_ENDPOINT=true

# MinIO (S3-compatible local object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_DISABLE_SSE=true
AWS_S3_DISABLE_CHECKSUMS=true
S3_STORAGE_EXPORTS_BUCKET=convex-exports
S3_STORAGE_FILES_BUCKET=convex-files
S3_STORAGE_MODULES_BUCKET=convex-modules
S3_STORAGE_SEARCH_BUCKET=convex-search
S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=convex-snapshot-imports

# Web app runtime
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_URL=http://backend:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-generated-admin-key
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-string

# Ingest worker wiring (all docker-contained)
INGEST_API_KEY=replace-with-random-string
WORKER_API_KEY=replace-with-another-random-string
INGEST_WORKER_URL=http://worker:8080
INGEST_BASE_URL=http://web:3000
VALKEY_URL=redis://valkey:6379/0
RQ_QUEUE_NAME=ingest
CATALOG_START_YEAR=2018
CATALOG_END_YEAR=2026
