# Docker port mapping
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791

# Optional backend identity label
INSTANCE_NAME=f1-pace-lab-local

# Optional logging level: error,warn,info,debug,trace
RUST_LOG=info

# Dashboard -> backend URL (keep aligned with PORT unless you have a reverse proxy)
NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210

# Keep metrics off by default for local setup
DISABLE_METRICS_ENDPOINT=true
