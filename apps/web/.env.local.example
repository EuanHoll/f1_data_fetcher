# Browser client URL for Convex React client
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Convex CLI self-hosted credentials (copy from repo root .env.local)
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-generated-admin-key

# Auth.js (required in production, recommended in dev)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-string

# Optional OAuth provider (used if set)
GITHUB_ID=
GITHUB_SECRET=

# Shared secret for worker -> web ingest endpoint
INGEST_API_KEY=replace-with-random-string

# Ingest control route -> worker control API
INGEST_WORKER_URL=http://127.0.0.1:8080
WORKER_API_KEY=replace-with-another-random-string
